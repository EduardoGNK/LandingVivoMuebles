# ============================================================
# BASE DE DATOS (Railway MySQL)
# Obtener desde: https://railway.app → tu proyecto → MySQL → Connect
# ============================================================
DATABASE_URL="mysql://usuario:password@host:3306/nombre_db"

# ============================================================
# NEXTAUTH
# NEXTAUTH_SECRET: genera uno con: openssl rand -base64 32
# NEXTAUTH_URL: URL pública de tu app (Vercel o dominio propio)
# ============================================================
NEXTAUTH_SECRET="genera-uno-con-openssl-rand-base64-32"
NEXTAUTH_URL="https://tu-app.vercel.app"

# ============================================================
# GOOGLE OAUTH
# Crear en: https://console.cloud.google.com → APIs → Credentials
# Authorized redirect URIs debe incluir:
#   https://tu-app.vercel.app/api/auth/callback/google
#   https://vivomuebles.cl/api/auth/callback/google (cuando tengas el dominio)
# ============================================================
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-tu-secret"

# ============================================================
# CLOUDINARY (para subida de imágenes de proyectos)
# Crear cuenta gratis en: https://cloudinary.com
# Obtener desde: Dashboard → API Keys
# ============================================================
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# ============================================================
# EMAIL (Brevo SMTP)
# ============================================================
BREVO_SMTP_USER="tu-smtp-user@smtp-brevo.com"
BREVO_SMTP_KEY="tu-smtp-key"
EMAIL_1="correo-destino-1@ejemplo.com"
EMAIL_2="correo-destino-2@ejemplo.com"

# ============================================================
# HUGGING FACE (IA - opcional)
# ============================================================
HF_TOKEN="hf_tu-token"
